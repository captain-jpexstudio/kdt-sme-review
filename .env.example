# --- Postgres ---
POSTGRES_USER=survey
POSTGRES_PASSWORD=pass
POSTGRES_DB=surveydb

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://survey:pass@db:5432/surveydb
JWT_SECRET=change-me-32bytes-minimum-secret-key
JWT_ACCESS_TTL_MIN=120
JWT_REFRESH_TTL_DAYS=7
# base64 32-byte Fernet key. 생성: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
PII_FERNET_KEY=
SIGNATURE_STORAGE=/data/signatures
AGREEMENT_VERSION=2026-06-19.v1

# --- Active Edit thresholds (spec §4.4) ---
MIN_WORD_CHANGES=1
MIN_CHANGE_RATIO=0.0
SUSPICIOUS_RATIO=0.05
GOOD_RATIO=0.30
SIGN_MIN_INK_RATIO=0.002

# --- Cloudflare Tunnel (공개 배포) ---
# Zero Trust > Tunnels 에서 발급한 터널 토큰(eyJ...). 시크릿 — 실제 .env에만, git 금지.
CF_TUNNEL_TOKEN=

# --- Frontend ---
# 로컬: http://localhost/api/v1 · 공개배포: https://<도메인>/api/v1
NEXT_PUBLIC_API_BASE=http://localhost/api/v1
